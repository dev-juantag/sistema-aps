generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Territorio {
  id           String       @id @default(uuid())
  codigo       String       @unique
  nombre       String
  descripcion  String?
  activo       Boolean      @default(true)
  whatsappLink String?
  atenciones   Atencion[]
  contratos    Contrato[]
  derivaciones Derivacion[]
  fichas       FichaHogar[]
  usuarios     User[]       @relation("UserSingleTerritorio")
  facturadores User[]       @relation("FacturadorTerritorios")
}

model Programa {
  id           String       @id @default(uuid())
  nombre       String       @unique
  meta         Int?
  atenciones   Atencion[]
  derivaciones Derivacion[]
  usuarios     User[]
}

model User {
  id                    String                    @id @default(uuid())
  nombre                String
  apellidos             String
  email                 String                    @unique
  password              String
  documento             String                    @unique
  rol                   Rol                       @default(AUXILIAR)
  programaId            String?
  createdAt             DateTime                  @default(now())
  activo                Boolean                   @default(true)
  lastLogin             DateTime?
  territorioId          String?
  updatedAt             DateTime                  @default(now()) @updatedAt
  recoveryCode          String?
  recoveryExpires       DateTime?
  telefono              String?
  lastDownloadAtenciones DateTime?
  lastDownloadIdentificaciones DateTime?
  atenciones            Atencion[]
  contratos             Contrato[]
  derivacionesRecibidas Derivacion[]              @relation("ProfesionalDerivacion")
  auditoriasContrato    EstadoContratoHistorial[]
  fichasCreadas         FichaHogar[]
  territoriosAsignados  Territorio[]              @relation("FacturadorTerritorios")
  programa              Programa?                 @relation(fields: [programaId], references: [id])
  territorio            Territorio?               @relation("UserSingleTerritorio", fields: [territorioId], references: [id])
  seguimientosRealizados SeguimientoFamiliar[]
}

model Contrato {
  id                  String                    @id @default(uuid())
  userId              String
  territorioId        String?
  perfil              String?
  estado              ContratoEstado            @default(SELECCIONADO)
  numeroContrato      String?                   @unique
  cdp                 String?                   @unique
  rp                  String?                   @unique
  numeroPoliza        String?                   @unique
  fechaRp             DateTime?
  fechaSello          DateTime?
  fechaPoliza         DateTime?
  fechaInicioPoliza   DateTime?
  fechaFinPoliza      DateTime?
  aseguradora         String?
  fechaInicio         DateTime?
  fechaFinal          DateTime?
  arl                 String?
  empresaArl          String?
  valorPago           Float?
  porcentajeEjecucion Float?
  fechaPago           DateTime?
  objeto              String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @default(now()) @updatedAt
  territorio          Territorio?               @relation(fields: [territorioId], references: [id])
  user                User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  historial           EstadoContratoHistorial[]
}

model EstadoContratoHistorial {
  id              String          @id @default(uuid())
  contratoId      String
  estadoAnterior  ContratoEstado?
  estadoNuevo     ContratoEstado
  fechaCambio     DateTime        @default(now())
  observaciones   String?
  modificadoPorId String
  contrato        Contrato        @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  modificadoPor   User            @relation(fields: [modificadoPorId], references: [id])
}

model FichaHogar {
  id                    String       @id @default(uuid())
  consecutivo           Int          @unique @default(autoincrement())
  estadoVisita          String
  observacionesRechazo  String?
  departamento          String
  municipio             String
  territorioId          String?
  microterritorio       String?
  direccion             String
  latitud               Float?
  longitud              Float?
  fechaDiligenciamiento DateTime     @default(now())
  encuestadorId         String?
  fuenteAgua            Int[]
  dispExcretas          Int[]
  aguasResiduales       Int[]
  dispResiduos          Int[]
  riesgoAccidente       Int[]
  animales              Int[]
  vacunacionMascotas    Boolean?
  vulnerabilidades      String[]
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @default(now()) @updatedAt
  apgar                 Int?
  apgarRespuestas       Int[]
  cantAnimales          Int?
  centroPoblado         String?
  cuidadorPrincipal     Boolean?
  descripcionUbicacion  String?
  ecomapa               Int?
  estratoSocial         Int?
  fuenteEnergia         Int?
  hacinamiento          Boolean?
  matParedes            Int?
  matPisos              Int?
  matTechos             Int?
  numDormitorios        Int?
  numEBS                String?
  numHogares            Int?
  numIntegrantes        Int?
  presenciaVectores     Boolean?
  prestadorPrimario     String?
  tipoFamilia           Int?
  tipoVivienda          Int?
  tipoViviendaDesc      String?
  uzpe                  String?
  zarit                 Int?
  codFicha              String?
  numFamilia            String?
  numHogar              String?
  familiogramaCodigo    String?
  encuestadorNombreRaw  String?
  encuestadorDocRaw     String?
  otrosJson             Json?
  puedeActualizarse     Boolean      @default(false)
  derivaciones          Derivacion[]
  encuestador           User?        @relation(fields: [encuestadorId], references: [id])
  territorio            Territorio?  @relation(fields: [territorioId], references: [id])
  pacientes             Paciente[]
  seguimientos          SeguimientoFamiliar[]
}

model Paciente {
  id                       String       @id @default(uuid())
  documento                String       @unique
  telefono                 String?
  direccion                String?
  fechaNacimiento          String
  createdAt                DateTime     @default(now())
  generoIdentidad          String?
  antecTransmisibles       Json?
  antecedentes             Json?
  apellidos                String
  diagNutricional          Int?
  discapacidades           Int[]
  eapb                     String?
  enfermedadAguda          Boolean?
  esquemaAtenciones        Boolean?
  esquemaVacunacion        Boolean?
  etnia                    Int?
  fichaId                  String?
  gestante                 String       @default("NA")
  grupoPoblacional         Int[]
  intervencionesPendientes Int[]
  lactanciaMaterna         Boolean?
  lactanciaMeses           Int?
  mesesGestacion           Int?
  nivelEducativo           Int?
  nombres                  String
  ocupacion                Int?
  parentesco               Int          @default(1)
  perimetroBraquial        Float?
  peso                     Float?
  practicaDeportiva        Boolean?
  puebloIndigena           String?
  recibeAtencionMedica     Boolean?
  regimen                  String?
  remisiones               String[]
  sexo                     String       @default("HOMBRE")
  talla                    Float?
  tipoDoc                  String       @default("CC")
  updatedAt                DateTime     @default(now()) @updatedAt
  estadoVital              String?      @default("VIVO")
  madreId                  String?
  padreId                  String?
  parejaId                 String?
  tipoHijo                 String?
  tipoPareja               String?
  barrerasAcceso           Int[]
  barrerasAccesoOtro       String?
  otrosJson                Json?
  atenciones               Atencion[]
  derivaciones             Derivacion[]
  ficha                    FichaHogar?  @relation(fields: [fichaId], references: [id], onDelete: Cascade)
}

model Derivacion {
  id                 String           @id @default(uuid())
  fichaId            String?
  territorioId       String?
  programaId         String?
  profesionalId      String?
  estado             DerivacionEstado @default(PENDIENTE)
  notaIdentificacion String?
  atencionId         String?          @unique
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @default(now()) @updatedAt
  pacienteId         String
  atencion           Atencion?        @relation("DerivacionAtencion", fields: [atencionId], references: [id])
  ficha              FichaHogar?      @relation(fields: [fichaId], references: [id])
  paciente           Paciente         @relation(fields: [pacienteId], references: [id])
  profesional        User?            @relation("ProfesionalDerivacion", fields: [profesionalId], references: [id])
  programa           Programa?        @relation(fields: [programaId], references: [id])
  territorio         Territorio?      @relation(fields: [territorioId], references: [id])
}

model Atencion {
  id                String            @id @default(uuid())
  pacienteId        String
  profesionalId     String
  programaId        String
  nota              String
  createdAt         DateTime          @default(now())
  estadoFacturacion     EstadoFacturacion @default(PENDIENTE)
  observacionFacturacion String?
  territorioId          String?
  updatedAt             DateTime          @default(now()) @updatedAt
  paciente              Paciente          @relation(fields: [pacienteId], references: [id])
  profesional           User              @relation(fields: [profesionalId], references: [id])
  programa              Programa          @relation(fields: [programaId], references: [id])
  territorio        Territorio?       @relation(fields: [territorioId], references: [id])
  derivacion        Derivacion?       @relation("DerivacionAtencion")
}

model SystemSettings {
  id                String   @id @default(uuid())
  currentStageStart DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt
}

enum Rol {
  ADMIN
  PROFESIONAL
  SUPERADMIN
  ADMINISTRATIVO
  ABOGADO
  AUXILIAR
  FACTURADOR
}

enum DerivacionEstado {
  PENDIENTE
  EN_PROCESO
  ATENDIDA
  RECHAZADA
}

enum ContratoEstado {
  SELECCIONADO
  SUBIENDO_DOCUMENTOS
  CREANDO_CONTRATO
  ESPERA_POLIZA
  ACTA_INICIO
  ASIGNACION_TERRITORIO
  ACTIVO
  FINALIZADO
}

enum EstadoFacturacion {
  NO_FACTURABLE
  PENDIENTE
  DEVUELTA
  FACTURADA
  EVOLUCIONADA_SAFIX
  GLOSADA
  PAGADA
}

model SeguimientoFamiliar {
  id                String       @id @default(uuid())
  fichaId           String
  observacion       String
  acuerdosCumplidos Boolean      @default(false)
  consecutivo       Int
  responsableId     String
  fecha             DateTime     @default(now())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @default(now()) @updatedAt

  ficha             FichaHogar   @relation(fields: [fichaId], references: [id], onDelete: Cascade)
  responsable       User         @relation(fields: [responsableId], references: [id])
}
